generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Profile {
  id            Int      @id
  name          String
  profile       String
  designation   String
  description   String   @db.Text
  email         String
  phone         String
  address       String
  github        String
  facebook      String
  linkedIn      String
  twitter       String
  stackOverflow String
  leetcode      String
  socialLinks   Json     @default("[]")
  devUsername   String
  resume        String
  heroSkills    Json
  hardWorker    Boolean  @default(true)
  quickLearner  Boolean  @default(true)
  problemSolver Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Skill {
  id        Int      @id
  name      String   @unique
  image     String   @default("")
  percentage Int     @default(0)
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id        Int      @id
  title     String
  company   String
  location  String
  duration  String
  description String @db.LongText
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Education {
  id          Int      @id
  title       String
  duration    String
  institution String
  department  String
  achievement String   @db.LongText
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StatsCounter {
  id        Int      @id
  label     String
  highlight String
  count     String
  icon      String
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Achievement {
  id        Int      @id
  title     String
  issuer    String
  date      String
  type      String
  image     String   @default("")
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceSection {
  id        Int      @id
  title     String
  subtitle  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          Int              @id
  slug        String           @unique
  name        String
  impression  String
  impressionCount Int          @default(0)
  description String           @db.Text
  content     String           @db.LongText
  isFeatured  Boolean          @default(false)
  icon        String
  status      Boolean          @default(true)
  views       Int              @default(0)
  sortOrder   Int
  comments    ServiceComment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ServiceComment {
  id         Int            @id @default(autoincrement())
  serviceId  Int
  photo      String
  comment    String         @db.Text
  impression String
  sortOrder  Int
  service    Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  replies    ServiceReply[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model ServiceReply {
  id         Int            @id @default(autoincrement())
  commentId  Int
  reply      String         @db.Text
  impression String
  sortOrder  Int
  comment    ServiceComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Project {
  id              Int      @id
  slug            String   @unique
  name            String
  description     String   @db.Text
  content         String   @db.LongText
  tools           Json
  role            String
  code            String
  demo            String
  image           String   @default("")
  views           Int      @default(0)
  impressionCount Int      @default(0)
  buttons         Json     @default("[]")
  sortOrder       Int
  comments        ProjectComment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProjectComment {
  id        Int            @id @default(autoincrement())
  projectId Int
  name      String
  comment   String         @db.Text
  sortOrder Int
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  replies   ProjectReply[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ProjectReply {
  id        Int            @id @default(autoincrement())
  commentId Int
  name      String
  reply     String         @db.Text
  sortOrder Int
  comment   ProjectComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Pricing {
  id          Int      @id
  slug        String   @unique
  name        String
  description String   @db.Text
  price       Decimal  @db.Decimal(10, 2)
  duration    String
  content     String   @db.LongText
  features    Json
  status      Boolean  @default(true)
  isPopular   Boolean  @default(false)
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Faq {
  id        Int      @id
  question  String
  answer    String   @db.LongText
  status    Boolean  @default(true)
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  content   String   @db.LongText
  image     String   @default("")
  company   String
  position  String   @default("")
  stars     Int      @default(5)
  status    Boolean  @default(true)
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id               Int       @id @default(autoincrement())
  title            String
  slug             String    @unique
  shortDescription String    @db.Text
  content          String    @db.LongText
  category         String
  tags             Json      @default("[]")
  featuredImage    String    @default("")
  metaTitle        String    @default("")
  metaDescription  String    @db.Text
  author           String
  status           String    @default("draft")
  publishDate      DateTime?
  commentsEnabled  Boolean   @default(true)
  isFeatured       Boolean   @default(false)
  views            Int       @default(0)
  impressionCount  Int       @default(0)
  shareCount       Int       @default(0)
  categories       ArticleCategoryAssignment[]
  comments         ArticleComment[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, publishDate])
  @@index([category])
}

model ResearchPublication {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique
  shortSummary    String   @db.Text @map("short_summary")
  content         String?  @db.LongText
  publicationType String   @map("publication_type")
  researchArea    String   @map("research_area")
  publisherName   String   @map("publisher_name")
  publishedDate   DateTime @map("published_date")
  doi             String?  @db.Text
  publicationUrl  String   @db.Text @map("publication_url")
  citationUrl     String?  @db.Text @map("citation_url")
  authors         Json?
  myAuthorRole    String?  @map("my_author_role")
  thumbnailImage  String?  @db.Text @map("thumbnail_image")
  views           Int      @default(0)
  impressionCount Int      @default(0) @map("impression_count")
  shareCount      Int      @default(0) @map("share_count")
  comments        ResearchComment[]
  isFeatured      Boolean  @default(false) @map("is_featured")
  status          String   @default("published")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([publicationType], map: "research_publications_publication_type_idx")
  @@index([researchArea], map: "research_publications_research_area_idx")
  @@index([status], map: "research_publications_status_idx")
  @@index([isFeatured], map: "research_publications_is_featured_idx")
  @@index([publishedDate], map: "research_publications_published_date_idx")
  @@map("research_publications")
}

model ResearchComment {
  id            Int           @id @default(autoincrement())
  publicationId Int           @map("publication_id")
  name          String
  comment       String        @db.Text
  sortOrder     Int           @map("sort_order")
  publication   ResearchPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  replies       ResearchReply[]
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([publicationId], map: "researchcomment_publication_id_idx")
  @@map("researchcomment")
}

model ResearchReply {
  id        Int             @id @default(autoincrement())
  commentId Int             @map("comment_id")
  name      String
  reply     String          @db.Text
  sortOrder Int             @map("sort_order")
  comment   ResearchComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@index([commentId], map: "researchreply_comment_id_idx")
  @@map("researchreply")
}

model ArticleComment {
  id        Int            @id @default(autoincrement())
  articleId Int
  name      String
  comment   String         @db.Text
  sortOrder Int
  article   Article        @relation(fields: [articleId], references: [id], onDelete: Cascade)
  replies   ArticleReply[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ArticleReply {
  id        Int            @id @default(autoincrement())
  commentId Int
  name      String
  reply     String         @db.Text
  sortOrder Int
  comment   ArticleComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ArticleCategory {
  id        Int                         @id @default(autoincrement())
  name      String                      @unique
  slug      String                      @unique
  articles  ArticleCategoryAssignment[]
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt
}

model ArticleCategoryAssignment {
  articleId  Int
  categoryId Int
  article    Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category   ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([articleId, categoryId])
  @@index([categoryId])
}

model ContactMessage {
  id           Int                  @id @default(autoincrement())
  name         String
  email        String
  subject      String               @default("")
  message      String               @db.Text
  photo        String               @default("")
  file         String               @default("")
  status       String               @default("not_solved")
  ticketToken  String               @unique
  createdAt    DateTime             @default(now())
  chatMessages ContactChatMessage[]
}

model ContactChatMessage {
  id               Int            @id @default(autoincrement())
  contactMessageId Int
  senderType       String
  senderName       String         @default("")
  message          String         @db.Text
  photo            String         @default("")
  file             String         @default("")
  createdAt        DateTime       @default(now())
  contactMessage   ContactMessage @relation(fields: [contactMessageId], references: [id], onDelete: Cascade)

  @@index([contactMessageId, createdAt])
}

enum AdminNotificationType {
  NEW_MESSAGE
  MESSAGE_REPLY
}

model AdminNotification {
  id             String                @id @default(cuid())
  type           AdminNotificationType
  title          String
  body           String?               @db.Text
  visitorName    String?
  visitorEmail   String?
  visitorPhone   String?
  messageId      Int?
  conversationId Int?
  preview        String?               @db.Text
  actionUrl      String?
  isRead         Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([isRead, createdAt])
  @@index([messageId, conversationId])
}

model EmergencyContact {
  id        Int      @id @default(autoincrement())
  label     String
  name      String
  icon      String
  link      String
  sortOrder Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("emergencycontact")
}

model AdminUser {
  id           Int      @id
  name         String
  email        String   @unique
  passwordHash String
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AiProvider {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  apiKey    String   @db.LongText @map("api_key")
  baseUrl   String   @default("") @map("base_url")
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ai_providers")
}

model AiSettings {
  id             Int      @id
  activeProvider String   @map("active_provider")
  modelName      String   @map("model_name")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ai_settings")
}

model AiTrainingEntry {
  id        Int      @id @default(autoincrement())
  question  String   @db.Text
  answer    String   @db.LongText
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ai_training_entries")
}

model SiteSettings {
  id                    Int      @id
  websiteTitle          String
  websiteDescription    String   @db.Text
  navTitle              String
  navSubtitle           String
  seoTitle              String
  seoDescription        String   @db.Text
  seoKeywords           String   @db.Text
  seoImage              String
  websiteIcon           String
  heroHeaderText        String   @db.Text
  heroDescription       String   @db.Text
  heroImage             String
  contactEmail          String
  mobileNumber          String
  footerText            String   @db.Text
  privacyPolicyHtml     String   @db.LongText
  termsConditionsHtml   String   @db.LongText
  canonicalUrl          String
  googleSiteVerification String
  googleVerificationFilePath String
  googleAnalyticsId     String
  googleTagManagerId    String
  adsenseHeadCode       String   @db.LongText
  adsensePageTopCode    String   @db.LongText
  adsenseBetweenSectionsCode String @db.LongText
  adsensePageBottomCode String   @db.LongText
  robotsIndexingEnabled Boolean  @default(true)
  robotsFollowEnabled   Boolean  @default(true)
  smtpHost              String
  smtpPort              Int      @default(587)
  smtpUser              String
  smtpPass              String   @db.Text
  smtpSecure            Boolean  @default(false)
  smtpFromEmail         String
  smtpFromName          String
  smtpReplyToEmail      String
  smtpToEmail           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AnalyticsSession {
  id          Int                  @id @default(autoincrement())
  sessionId   String               @unique
  firstPath   String               @default("/")
  lastPath    String               @default("/")
  ipAddress   String               @default("")
  country     String               @default("")
  region      String               @default("")
  city        String               @default("")
  userAgent   String?              @db.Text
  createdAt   DateTime             @default(now())
  lastSeenAt  DateTime             @default(now())
  dailyVisits AnalyticsDailyVisit[]
  pageViews   AnalyticsPageView[]
}

model AnalyticsDailyVisit {
  id         Int              @id @default(autoincrement())
  sessionRef Int
  visitDate  DateTime         @db.Date
  path       String           @default("/")
  createdAt  DateTime         @default(now())
  session    AnalyticsSession @relation(fields: [sessionRef], references: [id], onDelete: Cascade)

  @@unique([sessionRef, visitDate])
  @@index([visitDate])
}

model AnalyticsPageView {
  id           Int              @id @default(autoincrement())
  sessionRef    Int
  path         String           @default("/")
  firstViewedAt DateTime        @default(now())
  lastViewedAt DateTime         @default(now())
  viewCount    Int              @default(1)
  session      AnalyticsSession @relation(fields: [sessionRef], references: [id], onDelete: Cascade)

  @@unique([sessionRef, path])
  @@index([lastViewedAt])
}

model CvProfile {
  id                 Int        @id @default(autoincrement())
  title              String     @default("Optional CV Notes")
  extraNotes         String     @db.LongText
  targetRoles        Json       @default("[]")
  preferredCountries Json       @default("[]")
  resumeUrl          String     @default("")
  resumeFileName     String     @default("")
  resumeUpdatedAt    DateTime?
  isDefault          Boolean    @default(true)
  jobMatches         JobMatch[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@map("cv_profiles")
}

model JobSource {
  id          Int       @id @default(autoincrement())
  name        String
  type        String
  provider    String
  status      String    @default("active")
  config      Json      @default("{}")
  lastSyncedAt DateTime?
  jobPosts    JobPost[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type, provider])
  @@map("job_sources")
}

model JobPost {
  id                Int                @id @default(autoincrement())
  sourceId          Int?
  source            JobSource?         @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceType        String
  externalId        String?
  emailSubject      String             @default("")
  title             String
  company           String
  location          String             @default("")
  sourceUrl         String             @db.Text
  jobType           String             @default("")
  workMode          String             @default("")
  region            String             @default("")
  experienceLevel   String             @default("")
  sourceName        String             @default("")
  importMethod      String             @default("")
  descriptionStatus String             @default("READY")
  searchKeywordMatched String          @default("")
  description       String             @db.LongText
  rawContent        String             @db.LongText
  recruiterContacts RecruiterContact[]
  matches           JobMatch[]
  emailDrafts       JobEmailDraft[]
  status            String             @default("new")
  receivedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([sourceType, externalId])
  @@index([status, createdAt])
  @@index([company])
  @@index([descriptionStatus])
  @@index([importMethod])
  @@map("job_posts")
}

model JobSearchPreference {
  id                       Int      @id
  rolesJson                Json     @default("[]")
  customKeywordsJson       Json     @default("[]")
  jobTypesJson             Json     @default("[]")
  workModesJson            Json     @default("[]")
  regionsJson              Json     @default("[]")
  experienceLevelsJson     Json     @default("[]")
  preferredLanguagesJson   Json     @default("[]")
  maxJobsPerSync           Int      @default(25)
  minimumMatchScoreToDraft Int      @default(60)
  autoDraftEnabled         Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("job_search_preferences")
}

model JobBoardSource {
  id                 Int       @id @default(autoincrement())
  sourceName         String
  companyName        String    @default("")
  region             String
  sourceType         String
  baseUrl            String    @db.Text
  careersUrl         String    @db.Text
  detectedProvider   String    @default("")
  extractionStatus   String    @default("UNSUPPORTED")
  extractionMessage  String    @db.Text
  selectorConfigJson Json?
  lastImportStatsJson Json?
  enabled            Boolean   @default(false)
  notes              String    @db.Text
  requiresApiKey     Boolean   @default(false)
  apiKeyEncrypted    String?   @db.LongText
  lastSyncAt         DateTime?
  status             String    @default("Planned")
  importRuns         JobSourceImportRun[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([sourceName, region])
  @@index([enabled, sourceType])
  @@map("job_board_sources")
}

model JobSourceImportRun {
  id                    Int            @id @default(autoincrement())
  sourceId              Int
  source                JobBoardSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status                String
  startedAt             DateTime
  finishedAt            DateTime?
  importedCount         Int            @default(0)
  duplicateCount        Int            @default(0)
  needsDescriptionCount Int            @default(0)
  errorMessage          String         @db.Text
  createdAt             DateTime       @default(now())

  @@index([sourceId, createdAt])
  @@map("job_source_import_runs")
}

model JobMatch {
  id              Int       @id @default(autoincrement())
  jobPostId       Int
  jobPost         JobPost   @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  cvProfileId     Int?
  cvProfile       CvProfile? @relation(fields: [cvProfileId], references: [id], onDelete: SetNull)
  score           Int
  matchedSkills   Json      @default("[]")
  missingSkills   Json      @default("[]")
  summary         String    @db.Text
  aiAnalysis      Json      @default("{}")
  coverLetter     String    @db.LongText
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([jobPostId, cvProfileId])
  @@index([score])
  @@map("job_matches")
}

model RecruiterContact {
  id              Int      @id @default(autoincrement())
  jobPostId       Int?
  jobPost         JobPost? @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  emailDrafts      JobEmailDraft[]
  name            String   @default("")
  email           String
  source          String
  verification    String   @default("manual")
  verified        Boolean  @default(false)
  publicContext   String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@map("recruiter_contacts")
}

model JobEmailDraft {
  id                 Int               @id @default(autoincrement())
  jobPostId           Int
  jobPost             JobPost           @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  recruiterContactId  Int?
  recruiterContact    RecruiterContact? @relation(fields: [recruiterContactId], references: [id], onDelete: SetNull)
  toEmail             String             @default("")
  subject             String
  body                String             @db.LongText
  trackingId          String             @unique @default(cuid())
  aiProvider          String             @default("")
  aiModel             String             @default("")
  emailPromptUsed     String             @db.LongText
  coverLetterPromptUsed String           @db.LongText
  coverLetterText     String             @db.LongText
  coverLetterPdfUrl   String             @default("")
  cvUrl               String             @default("")
  adminApprovalRequired Boolean          @default(true)
  approvalStatus      String             @default("PENDING")
  status              String             @default("DRAFT")
  approvedAt          DateTime?
  approvedBy          String             @default("")
  rejectedAt          DateTime?
  rejectionReason     String             @db.Text
  sentAt              DateTime?
  openedAt            DateTime?
  lastOpenedAt        DateTime?
  openCount           Int                @default(0)
  clickedAt           DateTime?
  clickCount          Int                @default(0)
  providerMessageId   String             @default("")
  events              JobAgentEmailEvent[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([sentAt])
  @@map("job_email_drafts")
}

model JobAgentSettings {
  id                       Int      @id
  gmailConnectedEmail      String   @default("")
  gmailRefreshToken        String   @db.LongText
  gmailHistoryId           String   @default("")
  gmailQuery               String   @default("(from:linkedin OR from:indeed OR subject:(job alert) OR subject:(jobs for you)) newer_than:30d")
  dailySendLimit           Int      @default(5)
  sendsToday               Int      @default(0)
  sendLimitDate            DateTime?
  autoSendEnabled          Boolean  @default(false)
  defaultCvProfileId       Int?
  approvedApiSources       Json     @default("[]")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("job_agent_settings")
}

model JobAgentEmailSetting {
  id                    Int      @id
  adminId               Int?
  fromName              String   @default("")
  fromEmail             String   @default("")
  smtpHost              String   @default("smtp.gmail.com")
  smtpPort              Int      @default(465)
  smtpSecure            Boolean  @default(true)
  smtpUsername          String   @default("")
  smtpPasswordEncrypted String   @db.LongText
  dailySendLimit        Int      @default(5)
  isEnabled             Boolean  @default(false)
  openTrackingEnabled   Boolean  @default(false)
  clickTrackingEnabled  Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("job_agent_email_settings")
}

model JobAgentEmailEvent {
  id             Int           @id @default(autoincrement())
  draftId        Int
  draft          JobEmailDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  jobPostId      Int
  recipientEmail String
  eventType      String
  trackingId     String
  url            String        @db.Text
  userAgent      String        @db.Text
  ipHash         String        @default("")
  createdAt      DateTime      @default(now())

  @@index([draftId, eventType, createdAt])
  @@index([trackingId])
  @@index([jobPostId])
  @@map("job_agent_email_events")
}

model JobAgentAiSetting {
  id                         Int      @id
  aiProvider                 String   @default("DEEPSEEK")
  aiModel                    String   @default("deepseek-chat")
  deepseekApiKeyEncrypted    String?  @db.LongText
  geminiApiKeyEncrypted      String?  @db.LongText
  openaiApiKeyEncrypted      String?  @db.LongText
  fallbackProvider           String?
  fallbackEnabled            Boolean  @default(false)
  systemPrompt               String   @db.LongText
  recruiterEmailPrompt       String   @db.LongText
  coverLetterPrompt          String   @db.LongText
  tone                       String   @default("professional-natural")
  maxEmailWords              Int      @default(160)
  maxCoverLetterWords        Int      @default(450)
