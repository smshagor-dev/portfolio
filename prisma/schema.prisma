generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Profile {
  id            Int      @id
  name          String
  profile       String
  designation   String
  description   String   @db.Text
  email         String
  phone         String
  address       String
  github        String
  facebook      String
  linkedIn      String
  twitter       String
  stackOverflow String
  leetcode      String
  socialLinks   Json     @default("[]")
  devUsername   String
  resume        String
  heroSkills    Json
  hardWorker    Boolean  @default(true)
  quickLearner  Boolean  @default(true)
  problemSolver Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Skill {
  id        Int      @id
  name      String   @unique
  image     String   @default("")
  percentage Int     @default(0)
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id        Int      @id
  title     String
  company   String
  location  String
  duration  String
  description String @db.LongText
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Education {
  id          Int      @id
  title       String
  duration    String
  institution String
  department  String
  achievement String   @db.LongText
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StatsCounter {
  id        Int      @id
  label     String
  highlight String
  count     String
  icon      String
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Achievement {
  id        Int      @id
  title     String
  issuer    String
  date      String
  type      String
  image     String   @default("")
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceSection {
  id        Int      @id
  title     String
  subtitle  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          Int              @id
  slug        String           @unique
  name        String
  impression  String
  impressionCount Int          @default(0)
  description String           @db.Text
  content     String           @db.LongText
  isFeatured  Boolean          @default(false)
  icon        String
  status      Boolean          @default(true)
  views       Int              @default(0)
  sortOrder   Int
  comments    ServiceComment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ServiceComment {
  id         Int            @id @default(autoincrement())
  serviceId  Int
  photo      String
  comment    String         @db.Text
  impression String
  sortOrder  Int
  service    Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  replies    ServiceReply[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model ServiceReply {
  id         Int            @id @default(autoincrement())
  commentId  Int
  reply      String         @db.Text
  impression String
  sortOrder  Int
  comment    ServiceComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Project {
  id              Int      @id
  slug            String   @unique
  name            String
  description     String   @db.Text
  content         String   @db.LongText
  tools           Json
  role            String
  code            String
  demo            String
  image           String   @default("")
  views           Int      @default(0)
  impressionCount Int      @default(0)
  buttons         Json     @default("[]")
  sortOrder       Int
  comments        ProjectComment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProjectComment {
  id        Int            @id @default(autoincrement())
  projectId Int
  name      String
  comment   String         @db.Text
  sortOrder Int
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  replies   ProjectReply[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ProjectReply {
  id        Int            @id @default(autoincrement())
  commentId Int
  name      String
  reply     String         @db.Text
  sortOrder Int
  comment   ProjectComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Pricing {
  id          Int      @id
  slug        String   @unique
  name        String
  description String   @db.Text
  price       Decimal  @db.Decimal(10, 2)
  duration    String
  content     String   @db.LongText
  features    Json
  status      Boolean  @default(true)
  isPopular   Boolean  @default(false)
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  content   String   @db.LongText
  image     String   @default("")
  company   String
  position  String   @default("")
  stars     Int      @default(5)
  status    Boolean  @default(true)
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id               Int       @id @default(autoincrement())
  title            String
  slug             String    @unique
  shortDescription String    @db.Text
  content          String    @db.LongText
  category         String
  tags             Json      @default("[]")
  featuredImage    String    @default("")
  metaTitle        String    @default("")
  metaDescription  String    @db.Text
  author           String
  status           String    @default("draft")
  publishDate      DateTime?
  commentsEnabled  Boolean   @default(true)
  isFeatured       Boolean   @default(false)
  views            Int       @default(0)
  impressionCount  Int       @default(0)
  shareCount       Int       @default(0)
  categories       ArticleCategoryAssignment[]
  comments         ArticleComment[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, publishDate])
  @@index([category])
}

model ArticleComment {
  id        Int            @id @default(autoincrement())
  articleId Int
  name      String
  comment   String         @db.Text
  sortOrder Int
  article   Article        @relation(fields: [articleId], references: [id], onDelete: Cascade)
  replies   ArticleReply[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ArticleReply {
  id        Int            @id @default(autoincrement())
  commentId Int
  name      String
  reply     String         @db.Text
  sortOrder Int
  comment   ArticleComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ArticleCategory {
  id        Int                         @id @default(autoincrement())
  name      String                      @unique
  slug      String                      @unique
  articles  ArticleCategoryAssignment[]
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt
}

model ArticleCategoryAssignment {
  articleId  Int
  categoryId Int
  article    Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category   ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([articleId, categoryId])
  @@index([categoryId])
}

model ContactMessage {
  id           Int                  @id @default(autoincrement())
  name         String
  email        String
  subject      String               @default("")
  message      String               @db.Text
  photo        String               @default("")
  file         String               @default("")
  status       String               @default("not_solved")
  ticketToken  String               @unique
  createdAt    DateTime             @default(now())
  chatMessages ContactChatMessage[]
}

model ContactChatMessage {
  id               Int            @id @default(autoincrement())
  contactMessageId Int
  senderType       String
  senderName       String         @default("")
  message          String         @db.Text
  photo            String         @default("")
  file             String         @default("")
  createdAt        DateTime       @default(now())
  contactMessage   ContactMessage @relation(fields: [contactMessageId], references: [id], onDelete: Cascade)

  @@index([contactMessageId, createdAt])
}

model EmergencyContact {
  id        Int      @id @default(autoincrement())
  label     String
  name      String
  icon      String
  link      String
  sortOrder Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("emergencycontact")
}

model AdminUser {
  id           Int      @id
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSettings {
  id                    Int      @id
  websiteTitle          String
  websiteDescription    String   @db.Text
  navTitle              String
  navSubtitle           String
  seoTitle              String
  seoDescription        String   @db.Text
  seoKeywords           String   @db.Text
  seoImage              String
  websiteIcon           String
  heroHeaderText        String   @db.Text
  heroDescription       String   @db.Text
  heroImage             String
  contactEmail          String
  mobileNumber          String
  footerText            String   @db.Text
  canonicalUrl          String
  googleSiteVerification String
  googleAnalyticsId     String
  googleTagManagerId    String
  robotsIndexingEnabled Boolean  @default(true)
  robotsFollowEnabled   Boolean  @default(true)
  smtpHost              String
  smtpPort              Int      @default(587)
  smtpUser              String
  smtpPass              String   @db.Text
  smtpSecure            Boolean  @default(false)
  smtpFromEmail         String
  smtpFromName          String
  smtpReplyToEmail      String
  smtpToEmail           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AnalyticsSession {
  id          Int                  @id @default(autoincrement())
  sessionId   String               @unique
  firstPath   String               @default("/")
  lastPath    String               @default("/")
  ipAddress   String               @default("")
  country     String               @default("")
  region      String               @default("")
  city        String               @default("")
  userAgent   String?              @db.Text
  createdAt   DateTime             @default(now())
  lastSeenAt  DateTime             @default(now())
  dailyVisits AnalyticsDailyVisit[]
  pageViews   AnalyticsPageView[]
}

model AnalyticsDailyVisit {
  id         Int              @id @default(autoincrement())
  sessionRef Int
  visitDate  DateTime         @db.Date
  path       String           @default("/")
  createdAt  DateTime         @default(now())
  session    AnalyticsSession @relation(fields: [sessionRef], references: [id], onDelete: Cascade)

  @@unique([sessionRef, visitDate])
  @@index([visitDate])
}

model AnalyticsPageView {
  id           Int              @id @default(autoincrement())
  sessionRef    Int
  path         String           @default("/")
  firstViewedAt DateTime        @default(now())
  lastViewedAt DateTime         @default(now())
  viewCount    Int              @default(1)
  session      AnalyticsSession @relation(fields: [sessionRef], references: [id], onDelete: Cascade)

  @@unique([sessionRef, path])
  @@index([lastViewedAt])
}
