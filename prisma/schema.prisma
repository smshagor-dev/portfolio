generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Profile {
  id             Int      @id
  name           String
  profile        String
  designation    String
  description    String   @db.Text
  email          String
  phone          String
  address        String
  github         String
  facebook       String
  linkedIn       String
  twitter        String
  stackOverflow  String
  leetcode       String
  socialLinks    Json     @default("[]")
  devUsername    String
  resume         String
  heroSkills     Json
  hardWorker     Boolean  @default(true)
  quickLearner   Boolean  @default(true)
  problemSolver  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Skill {
  id        Int      @id
  name      String   @unique
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id        Int      @id
  title     String
  company   String
  duration  String
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Education {
  id          Int      @id
  title       String
  duration    String
  institution String
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StatsCounter {
  id        Int      @id
  label     String
  highlight String
  count     String
  icon      String
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          Int      @id
  name        String
  description String   @db.Text
  tools       Json
  role        String
  code        String
  demo        String
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model AdminUser {
  id           Int      @id
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
