{
  "name": "developer-portfolio",
  "description": "Portfolio of Shahanur Islam Shagor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:prepare": "node server/scripts/ensure-db.js && node server/scripts/run-prisma.js generate && node server/scripts/run-prisma.js migrate deploy && node server/scripts/run-prisma.js db seed",
    "dev": "concurrently -k -n backend,frontend -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "npm run db:prepare && nodemon server/index.js",
    "dev:web": "wait-on tcp:5000 && next dev",
    "build": "next build",
    "start": "npm run build && concurrently -k -n backend,frontend -c blue,green \"npm run start:server\" \"npm run start:web\"",
    "start:server": "npm run db:prepare && node server/index.js",
    "start:web": "wait-on tcp:5000 && next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@emailjs/browser": "^4.3.1",
    "@next/third-parties": "^16.0.1",
    "@prisma/client": "^6.19.0",
    "axios": "^1.6.8",
    "bcryptjs": "^3.0.3",
    "ckeditor5": "^48.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.8.0",
    "multer": "^2.1.1",
    "mysql2": "^3.22.1",
    "next": "16.0.10",
    "nodemailer": "^6.9.15",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-fast-marquee": "^1.6.2",
    "react-google-recaptcha": "^3.1.0",
    "react-icons": "^4.11.0",
    "react-toastify": "^10.0.4",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-next": "^16.0.1",
    "postcss": "latest",
    "sass": "^1.69.5",
    "tailwindcss": "latest"
  }
}
